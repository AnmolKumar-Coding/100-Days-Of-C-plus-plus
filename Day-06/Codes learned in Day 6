// Find sum from 1 to N?

int main(){

    int N;

    int sum = 0;
    int num = 1;

    cout << " Type the value of N" << endl;
    cin >> N;

    while (num <= N){
        
        sum = sum + num;

        num = num + 1;

    } 
    cout << " the num of 1 to " << N << endl;
    cout << sum << endl;
}


//find n! ?

int main(){

    double N;

    double ans = 1;
    double num = 1;

    cout << "enter the value of N" << endl;
    cin >> N;

    while(num <= N){

        ans = ans * num;

        num = num + 1;
    }

    cout << "Multiplication of 1 to " << N << " is " << endl;

    cout << ans << endl;
}


